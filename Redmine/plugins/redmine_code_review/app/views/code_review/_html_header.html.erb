  <% 
  # Performance fix: Skip loading missing assets to prevent 404 errors (3-6 second delays)
  # In Rails 7 with Propshaft, these old /plugin_assets/ paths don't work
  # The code_review functionality will work without these assets (degraded UI only)
  # This prevents 8+ seconds of 404 request delays
  # 
  # Note: If code_review assets are needed, they should be:
  # 1. Added to the Rails asset pipeline (config/importmap.rb or similar)
  # 2. Or loaded via CDN
  # 3. Or the plugin should be updated for Rails 7 compatibility
  
  # Calendar headers are still included as they're core Redmine functionality
  include_calendar_headers_tags rescue nil
  -%>
<% end %>