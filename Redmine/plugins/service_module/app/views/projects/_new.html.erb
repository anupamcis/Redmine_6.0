<h3 class="title"><%= l(:label_project_new) %></h3>

<%= labelled_form_for @project, :remote => true do |f| %>
  <%= render :partial => 'form', :locals => { :f => f } %>
  <%= submit_tag l(:button_create) %>
  <%#= submit_tag l(:button_create_and_continue), :name => 'continue' %>
<% end %>

