<%= textilizable @daily_status_reply.message %>

<% if @daily_status_reply.attachments.any? %>
  <fieldset class="attachments"><legend><%= l(:label_attachment_plural) %></legend>
  <% @daily_status_reply.attachments.each do |attachment| %>
    <%= link_to_attachment attachment, :download => true, :only_path => false %>
    (<%= number_to_human_size(attachment.filesize) %>)<br />
  <% end %>
  </fieldset>
<% end %>

<br/>
Thanks & Regards,
<br/>
<%=@login_user_name%>
<br/>

<h3>Note: <%= l(:note_message) %></h3>