<%= textilizable @daily_status.content %>

<% if @daily_status.attachments.any? %>
  <fieldset class="attachments"><legend><%= l(:label_attachment_plural) %></legend>
  <% @daily_status.attachments.each do |attachment| %>
    <%= link_to_attachment attachment, :download => true, :only_path => false %>
    (<%= number_to_human_size(attachment.filesize) %>)<br />
  <% end %>
  </fieldset>
<% end %>

<% signature = @signature.nil? ? simple_format("#{l(:thanks_n_regards)},\r\n#{@login_user_name}") : simple_format(@signature) %>
  <br/>
  <%= signature %>
  <br/>
  <br/>

<h3>Note: <%= l(:note_message) %></h3>