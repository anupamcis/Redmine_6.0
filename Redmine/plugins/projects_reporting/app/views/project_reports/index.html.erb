    border-bottom: 0.1px solid black;
  }

  table.list th {
    border: 0.1px solid;
  }

  .estimated-graph-box{ height:420px; overflow-x:hidden; border: 5px solid #919191; display: flex; padding: 30px 0; box-sizing: border-box;  }
