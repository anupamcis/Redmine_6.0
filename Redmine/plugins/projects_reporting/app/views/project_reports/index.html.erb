<style type="text/css">
  .project_table table.list {
    border: 1px solid #000;
    background: #fff;
  }

  .project_table table.list thead th {
    padding: 10px 8px;
    font-size: 14px;
    background: #5f5f5f;
    font-weight: normal;
    text-transform: capitalize;
    color: #fff;
    border-color: #464646;
    vertical-align: middle;
    font-weight: 700;
