<%new_data = {} %>
<% data.each{|val| new_data[val.name] = eval("@total_issues_by_#{type}[val]")} %>
<% if data.present? && !new_data.values.all? { |el| el.nil? } %>
	<div id="containerColumn<%=type.titleize.gsub(' ','')%>" class="double_chart" ></div>

	<script type="text/javascript">
	var chart;
	$(document).ready(function() {
		chart = new Highcharts.Chart({
				credits: {
				enabled: false
			},
			chart: {
				renderTo: '<%= "containerColumn#{type.titleize.gsub(' ','')}"%>',
				type: 'column'
			},

			title: {
				text: '<%= ::I18n.t("#{type}_issue_label_title") %>'
			},
			xAxis: {
				categories: <%=data.map{ |situacao| situacao.name.to_s}.inspect.html_safe%>,
				labels: {enabled: false}
			},
			yAxis: {
				min: 0,
				title: {
					text: '<%=t :tasks_label%> ',
				}
			},
			legend: {
				enabled: true
			},
			tooltip: {
				formatter: function() {
					return '<b>'+ this.series.name +'</b><br/>'+
						'<%=t :tasks_label%> '+ Highcharts.numberFormat(this.y, 0);
				}
			},
					series: [
									<%new_data.each do |key, val|%>
									{
													name: "<%= key %>",
													data: [<%= val %>],
													cursor: 'pointer',

										dataLabels: {
																													enabled: true,
																													rotation: -90,
																													color: '#FFFFFF',
																													align: 'right',
																													x: -3,
																													y: 10,
																													formatter: function() {
																																	return this.y;
																													},
																													style: {
																																	font: 'normal 13px Verdana, sans-serif'
																													}
																									}
										}<%if !(data.last.name == key)%>,<%end%>
									<%end%>
									]
		});
	});
	</script>
<% end %>
