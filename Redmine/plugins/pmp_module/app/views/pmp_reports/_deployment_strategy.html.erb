<% if User.current.allowed_to?(:view_deployment_strategies, @project, global: true) %>
  <h2><%= l(:deployment_strategies) %></h2>

  <%= render partial: "deployment_strategies/index" %>
<%end%>

<% if User.current.allowed_to?(:create_deployment_strategies, @project, global: true)%>
  <%= link_to l(:add_deployment_strategy), new_project_deployment_strategy_path(@project, :back_url => request.original_fullpath), :class => 'icon icon-add', :title => l(:add), remote: true %>
<%end%>