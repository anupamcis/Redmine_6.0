<% if @project.try(:hardware_software_suplied_by_clients).any? %>
  <div class="autoscroll">
    <table class="list">
      <thead>
        <tr>
          <th><%= l(:field_client_supplied_item) %></th>
          <th><%= l(:field_remarks) %></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% for hardware_software_suplied_by_client in @project.hardware_software_suplied_by_clients -%>
        <tr class="<%= cycle("odd", "even") %>">
          <td class="firstname"><%= hardware_software_suplied_by_client.client_supplied_item %></td>
          <td class="lastname"><%= hardware_software_suplied_by_client.remarks %></td>
          <td class="buttons">
            <%= link_to l(:edit), edit_project_hardware_software_suplied_by_client_path(@project,hardware_software_suplied_by_client, :back_url => request.original_fullpath), class: "icon icon-edit", title: "Edit", remote: true if User.current.allowed_to?(:update_hardware_software_suplied_by_clients, @project, global: true)%>
            <%= delete_link project_hardware_software_suplied_by_client_path(@project,hardware_software_suplied_by_client, :back_url => request.original_fullpath),title: "Delete" if User.current.allowed_to?(:delete_hardware_software_suplied_by_clients, @project, global: true)%>
          </td>
        </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else%>
<p class="nodata"><%= l(:label_no_data) %></p>
<% end %>