<% if @project.try(:staff_needs).any? %>
  <div class="autoscroll">
    <table class="list">
      <thead>
        <tr>
          <th><%= l(:field_role) %></th>
          <th><%= l(:field_allocated_persons) %></th>
          <th><%= l(:field_no_of_persons) %></th>
          <th><%= l(:field_min_experience1) %></th>
          <th><%= l(:field_from_date) %></th>
          <th><%= l(:field_to_date) %></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% for staff_need in @project.staff_needs -%>
          <tr class="<%= cycle("odd", "even") %>">
            <td class="firstname"><%= staff_need.role %></td>
            <td class="firstname"><%= staff_need.allocated_persons.map(&:name).join(",")%></td>
            <td class="lastname"><%= staff_need.no_of_persons %></td>
            <td class="lastname"><%= "#{staff_need.min_experience.to_i/12}.#{staff_need.min_experience.to_i%12}" %></td>
            <td class="lastname"><%= format_date(staff_need.from_date) %></td>
            <td class="lastname"><%= format_date(staff_need.to_date) %></td>
            <td class="buttons">
              <%= link_to l(:edit), edit_project_staff_need_path(@project,staff_need, :back_url => request.original_fullpath), class: "icon icon-edit", :title => "Edit", remote: true if User.current.allowed_to?(:update_staff_needs, @project, global: true)%>
              <%= delete_link project_staff_need_path(@project,staff_need, :back_url => request.original_fullpath), :title => "Delete" if User.current.allowed_to?(:delete_staff_needs, @project, global: true) && staff_need.is_deleted %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else%>
  <p class="nodata"><%= l(:label_no_data) %></p>
<% end %>