<h3 class="title"><%= l(:edit_monitoring_review)%> </h3>

<%= labelled_form_for [@project, @project_monitoring_review], :remote => true do |f| %>
  <%= render :partial => 'form', :locals => { :f => f } %>
  <%= submit_tag l(:button_save), data: { disable_with: "Please wait..." } %>  
<% end %>

<style type="text/css">
  .ui-dialog-content .box {
    background: hsla(0, 0%, 0%, 0) none repeat scroll 0 0;
    border: solid;
    box-shadow: none;
    padding: 15px 31px 0 0;
  }
</style>