<% if @project.try(:project_monitoring_reviews).any? && @project.milestones.any? %>
  <div class="autoscroll">
    <table class="list">
      <thead>
        <tr>
          <th><%= l(:field_milestone) %></th>
          <th><%= l(:field_frequency) %></th>
          <th><%= l(:field_remarks) %></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% for project_monitoring_review in @project.project_monitoring_reviews -%>
        <tr class="<%= cycle("odd", "even") %>">
          <td class="firstname"><%= project_monitoring_review.name %></td>
          <td class="lastname"><%= project_monitoring_review.frequency %></td>
          <td class="lastname"><%= project_monitoring_review.remarks %></td>
          <td class="buttons">
            <%= link_to l(:edit), edit_project_project_monitoring_review_path(@project,project_monitoring_review, :back_url => request.original_fullpath), class: "icon icon-edit", :title => l(:edit), remote: true if User.current.allowed_to?(:update_project_monitoring_reviews, @project, global: true)%>
            <%= delete_link project_project_monitoring_review_path(@project,project_monitoring_review, :back_url => request.original_fullpath), :title => "Delete" if User.current.allowed_to?(:delete_project_monitoring_reviews, @project, global: true)%>
          </td>
        </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else%>
  <p class="nodata"><%= l(:label_no_data) %></p>
<% end %>