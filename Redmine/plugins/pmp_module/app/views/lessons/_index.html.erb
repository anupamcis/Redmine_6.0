<% if @project.try(:lessons).any? %>
  <div class="autoscroll">
    <table class="list">
      <thead>
        <tr>
          <th><%= l(:field_sdlc_phase) %></th>
          <th><%= l(:field_description) %></th>
          <th><%= l(:field_lesson_learnt_type) %></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% for lesson in @project.lessons -%>
        <tr class="<%= cycle("odd", "even") %>">
          <td class="firstname"><%= lesson.sdlc_phase %></td>
          <td class="firstname"><%= lesson.description.html_safe %></td>
          <td class="lastname"><%= lesson.lesson_learnt_type %></td>
          <td class="buttons">
            <%= link_to l(:edit), edit_project_lesson_path(@project,lesson, :back_url => request.original_fullpath), class: "icon icon-edit", :title => l(:edit), remote: true if User.current.allowed_to?(:update_lessons, @project, global: true) %>
            <%= delete_link project_lesson_path(@project,lesson, :back_url => request.original_fullpath), :title => "Delete" if User.current.allowed_to?(:delete_lessons, @project, global: true)%>
          </td>
        </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else%>
  <p class="nodata"><%= l(:label_no_data) %></p>
<% end %>

<% if User.current.allowed_to?(:create_lessons, @project, global: true)%>
  <%= link_to l(:add_lesson), new_project_lesson_path(@project, :back_url => request.original_fullpath), :class => 'icon icon-add', :title => l(:add), remote: true %>
<%end%>

<br><br>

<h2><%= l(:summary) %></h2>

<div class="autoscroll">
  <table class="list">
    <thead>
      <tr>
        <th><%= l(:item_name) %></th>
        <th><%= l(:count) %></th>
      </tr>
    </thead>
    <tbody>
      <tr class="<%= cycle("odd", "") %>">
        <td class="firstname"><%= l(:went_wrong) %></td>
        <td class="lastname"><%= @project.lesson_type_count(l(:went_wrong)) %></td>
      </tr>
      <tr class="<%= cycle("even", "") %>">
        <td class="firstname"><%= l(:went_right) %></td>
        <td class="lastname"><%= @project.lesson_type_count(l(:went_right)) %></td>
      </tr>
      <tr class="<%= cycle("odd", "") %>">
        <td class="firstname"><%= l(:best_practice) %></td>
        <td class="lastname"><%= @project.lesson_type_count(l(:best_practice)) %></td>
      </tr>
    </tbody>
  </table>
</div>