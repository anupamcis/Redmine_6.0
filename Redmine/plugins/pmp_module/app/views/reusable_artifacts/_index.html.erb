<% if @project.try(:reusable_artifacts).any? %>
  <div class="autoscroll">
    <table class="list">
      <thead>
        <tr>
          <th><%= l(:field_reusable_component_name) %></th>
          <th><%= l(:field_short_description) %></th>
          <th><%= l(:field_url) %></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% for reusable_artifact in @project.reusable_artifacts -%>
          <tr class="<%= cycle("odd", "even") %>">
            <td class="firstname"><%= reusable_artifact.reusable_component_name %></td>
            <td class="lastname"><%= reusable_artifact.short_description %></td>
            <td class="lastname"><%= reusable_artifact.url %></td>
            <td class="buttons">
              <%= link_to l(:edit), edit_project_reusable_artifact_path(@project,reusable_artifact, :back_url => request.original_fullpath), class: "icon icon-edit", :title => l(:edit), remote: true if User.current.allowed_to?(:update_reusable_artifacts, @project, global: true)%>
              <%= delete_link project_reusable_artifact_path(@project,reusable_artifact, :back_url => request.original_fullpath), :title => "Delete" if User.current.allowed_to?(:delete_reusable_artifacts, @project, global: true)%>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else%>
  <p class="nodata"><%= l(:label_no_data) %></p>
<% end %>