<div class="contextual">
<%= link_to l(:label_profile), company_path(@company), :class => 'icon icon-user' %>
</div>

<%= title [l(:label_company_plural), companies_path], @company.name %>

<%= labelled_form_for @company do |f| %>
  <%= render :partial => 'form', :locals => { :f => f } %>
  <p><%= submit_tag l(:button_save) %></p>  
<% end %>

