<%= error_messages_for 'company' %>

<div id="company_form">
    <fieldset class="box tabular">
      <legend><%=l(:label_information_plural)%></legend>
      <p><%= f.text_field :name, :required => true, :size => 25  %></p>
      <p><%= f.text_field :phone_number %></p>
      <p><%= f.text_field :fax_number %></p>
      <p><%= f.text_area :address %></p>
      <p><%= f.text_field :homepage %></p>
    </fieldset></br> 
</div>
